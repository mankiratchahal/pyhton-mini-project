    total_rented = 0
    total_collection = 0

    def __init__(self, vehicle_no):
        self.vehicle_no = vehicle_no

    def calculate_rent(self, km):
        pass

    @classmethod
    def update_daily_data(cls, amount):
        cls.total_rented += 1
        cls.total_collection += amount

    @classmethod
    def show_daily_report(cls):
        print("\n===== DAILY REPORT =====")
        print("Total Vehicles Rented :", cls.total_rented)
        print("Total Collection      : ₹", cls.total_collection)


class Bike(Vehicle):
    BASE_KM = 250
    BASE_RENT = 2000
    EXTRA_CHARGE = 5

    def calculate_rent(self, km):
        if km <= self.BASE_KM:
            rent = self.BASE_RENT
        else:
            rent = self.BASE_RENT + (km - self.BASE_KM) * self.EXTRA_CHARGE

        Vehicle.update_daily_data(rent)
        return rent


